{
  "manifest_version": 3,
  "name": "VLL — Video Language Learner",
  "version": "1.0.0",
  "description": "Aprenda chinês assistindo YouTube. Legendas multi-camadas (Hanzi + Pinyin + Tradução), vocabulário com cores e exportação para Anki.",
  "permissions": [
    "activeTab",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["src/messages.shared.js", "src/config.shared.js", "src/network.shared.js", "src/vocab.shared.js", "src/subtitles.shared.js", "src/subtitles.js", "src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/dictionary.json"],
      "matches": ["*://*.youtube.com/*"]
    }
  ]
}
